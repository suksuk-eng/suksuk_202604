  [18,      3, '중', '본문',   'T/F 판별 — Simon의 마들렌 글 내용 일치 (④ 할머니 레시피 → F)', '✅'],
  [19,      2, '하', '본문',   '문장 삽입 — "best when come right out of the oven" 위치 (ⓓ)', '✅'],
  [20,      4, '상', '문법',   '어법상 옳지 않은 것 — ⓐ what→that 관계대명사 오류', '✅'],
  ['서5',   4, '상', '본문',   '조건 영작 — <em>The crisp sound of eating chips made me feel better.</em>', '✅'],
  ['서6-1', 3, '중', '대화문', '영수증 대화완성 — <em>I\'d like to order two bottles of water.</em> (8~9단어)', '△'],
  ['서6-2', 2, '하', '대화문', '영수증 대화완성 — <em>Is it for here or to go?</em> (7단어)', '✅'],
  ['서7-1', 3, '상', '본문',   '레시피 영작 — <em>Add flour to the bowl and mix it.</em> (어순 오류 주의)', '△'],
  ['서7-2', 3, '중', '본문',   '레시피 영작 — <em>Pour the mixture into the madeleine pan.</em>', '✅'],
  ['서8-1', 3, '중', '문법',   'so that 영작 — <em>Turn up the volume so that everyone can hear.</em>', '✅'],
  ['서8-2', 3, '중', '문법',   'so that 영작 — <em>Jenny went home early so that she could take a rest.</em>', '✅'],
];

const diffMap = {
  '상': {cls:'high', label:'상 ★★★'},
  '중': {cls:'mid',  label:'중 ★★☆'},
  '하': {cls:'low',  label:'하 ★☆☆'},
};
const areaMap = {
  '대화문': 'dialogue',
  '본문':   'text',
  '어휘':   'vocab',
  '문법':   'grammar',
  '서답형': 'written', // fallback
};

const tbody = document.getElementById('q-table');
questions.forEach(([num, pts, diff, area, point, result]) => {
  const isWritten = typeof num === 'string';
  const isWrong   = result === '❌';
  const isPartial = result === '△';
  const tr = document.createElement('tr');
  if (isWrong)   tr.className = 'wrong-row';
  else if (isPartial) tr.className = 'partial-row';
  else if (isWritten) tr.className = 'written-row';

  const d = diffMap[diff];
  const areaCls = areaMap[area] || 'text';
  const resultHtml = result === '✅' ? `<span class="result-ok">✅</span>`
                   : result === '❌' ? `<span class="result-fail">❌</span>`
                   : `<span class="result-part">△</span>`;

  tr.innerHTML = `
    <td><span class="num-badge ${isWritten?'written':''}">${num}</span></td>
    <td style="text-align:center;font-weight:700;">${pts}점</td>
    <td style="text-align:center;"><span class="badge ${d.cls}">${d.label}</span></td>
    <td style="text-align:center;"><span class="badge ${areaCls}">${area}</span></td>
    <td class="point-text">${point}</td>
    <td style="text-align:center;">${resultHtml}</td>
  `;
  tbody.appendChild(tr);
});

// Scroll fade-in
const obs = new IntersectionObserver(entries => {
  entries.forEach(e => { if(e.isIntersecting) { e.target.classList.add('visible'); } });
}, { threshold: 0.08 });
document.querySelectorAll('.fade-in').forEach(el => obs.observe(el));

// Animate bars on load
window.addEventListener('load', () => {
  const fills = document.querySelectorAll('.score-bar-fill, .bar-fill');
  fills.forEach(f => {
    const w = f.style.width;
    f.style.width = '0';
    setTimeout(() => { f.style.width = w; }, 200);
  });
});
</script>
</body>
</html>
